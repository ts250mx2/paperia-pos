DB_HOST=hlsistemas.com
DB_USER=kyk
DB_PASSWORD=
DB_NAME=BDPaperia
DB_PORT=3306
DB_CONNECTION_LIMIT=10

# Asistente Lapi (IA). Consigue tu llave en https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Configuración de Modelos de IA
# Forzar un modelo único para todas las opciones (opcional):
# ANTHROPIC_MODEL=claude-opus-4-8

# Modelos individuales por opción del menú (modelos recomendados):
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_OPUS=claude-opus-4-8

# Soporte de 'thinking' (razonamiento) y 'effort' (esfuerzo) por modelo (true/false)
# Haiku 4.5: el más rápido; no soporta 'effort' ni razonamiento profundo
ANTHROPIC_MODEL_HAIKU_THINKING=false
ANTHROPIC_MODEL_HAIKU_EFFORT=false
# Sonnet 4.6: soporta thinking adaptativo y effort
ANTHROPIC_MODEL_SONNET_THINKING=true
ANTHROPIC_MODEL_SONNET_EFFORT=true
# Opus 4.8: el más potente; soporta thinking adaptativo y effort
ANTHROPIC_MODEL_OPUS_THINKING=true
ANTHROPIC_MODEL_OPUS_EFFORT=true
